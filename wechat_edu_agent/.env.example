# OpenAI-compatible LLM settings
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen3.5-9b
LLM_JSON_MODE=off
# off | json_object | json_schema

# DeepSeek example
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=your_api_key
# LLM_MODEL=deepseek-chat

OUTPUT_DIR=outputs

# Search provider: manual | dashscope | tavily | auto
# auto tries dashscope → tavily → falls back to manual
SEARCH_PROVIDER=manual

# DashScope (Alibaba Cloud) — for dashscope/auto search
DASHSCOPE_API_KEY=your_dashscope_api_key

# Tavily Search — for tavily/auto search
TAVILY_API_KEY=your_tavily_api_key
